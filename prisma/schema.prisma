generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto]
}

model User {
  idx                  Int                  @id @default(autoincrement())
  user_id              String               @unique
  password             String?
  nickname             String               @unique
  profile_img          String               @default("")
  oauth_provider       String?
  oauth_provider_id    String?
  is_admin             Boolean              @default(false)
  is_identity_verified Boolean              @default(false)
  identity_verified_at DateTime?
  identity_ci_hash     String?              @unique
  created_at           DateTime             @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at           DateTime             @updatedAt
  articles             Article[]            @relation("ArticleAuthor")
  blacklistedBy        Blacklist[]          @relation("BlacklistedUser")
  blacklistedUsers     Blacklist[]          @relation("BlacklistOwner")
  bookmarkedBy         Bookmark[]           @relation("UserBookmarkedBy")
  bookmarksMade        Bookmark[]           @relation("UserBookmarksMade")
  bootpayTransactions  BootpayTransaction[]
  broadcastSetting     BroadcastSetting?
  channel              Channel?
  coinBalance          CoinBalance?
  coinTopups           CoinTopup[]
  sentDonations        Donation[]           @relation("SentDonations")
  receivedDonations    Donation[]           @relation("ReceivedDonations")
  fanLevel             FanLevel[]           @relation("CreatorRankTiers")
  fans                 Fan[]                @relation("UserFans")
  following            Fan[]                @relation("UserFollowing")
  ivs                  IVSChannel?
  managers             Manager[]            @relation("CreatorManaged")
  managedCreators      Manager[]            @relation("UserManager")
  paymentTransactions  PaymentTransaction[]
  payoutCoins          PayoutCoin[]         @relation("PayoutCoins")
  policyAgreements     PolicyAgreement[]    @relation("UserPolicyAgreements")
  blockedBy            PostBlockedUsers[]   @relation("PostBlockedUser")
  blockedUsers         PostBlockedUsers[]   @relation("PostBlockingUser")
  postSettings         PostSettings?
  receivedPosts        Posts[]              @relation("ReceivedPosts")
  sentPosts            Posts[]              @relation("SentPosts")
  settlements          Settlement[]         @relation("Settlements")
  streams              Stream?              @relation("StreamData")
  userDetail           UserDetail?
  UserTerms            UserTerms[]
  widgetTokens         WidgetToken[]

  @@map("users")
}

model UserDetail {
  user_idx        Int      @id
  name            String
  sex             String
  resident_number String
  phone           String
  email           String   @unique
  address         String
  created_at      DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  User            User     @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@map("user_details")
}

model Terms {
  id            Int         @id @default(autoincrement())
  version       Float
  content       String
  effectiveDate DateTime
  created_at    DateTime    @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  UserTerms     UserTerms[]

  @@map("terms")
}

model UserTerms {
  id        Int      @id @default(autoincrement())
  agreedAt  DateTime
  createdAt DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  user_idx  Int
  terms_id  Int
  terms     Terms    @relation(fields: [terms_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@unique([user_idx, terms_id])
  @@map("user_terms")
}

model Channel {
  user_idx         Int       @id
  title            String    @default("")
  bookmark         Int       @default(0)
  recommend        Int       @default(0)
  watch            Int       @default(0)
  month_time       Int       @default(0)
  total_time       Int       @default(0)
  first_start_time DateTime?
  createdAt        DateTime  @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  User             User      @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@map("channels")
}

model BroadcastSetting {
  user_idx  Int      @id
  title     String
  is_adult  Boolean  @default(false)
  is_pw     Boolean  @default(false)
  is_fan    Boolean  @default(false)
  fan_level Int      @default(1)
  password  String?
  createdAt DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@map("broadcast_settings")
}

model IVSChannel {
  user_idx               Int      @id
  channel_id             String   @unique
  arn                    String   @unique
  ingest_endpoint        String
  playback_url           String   @unique
  stream_key             String   @unique
  stream_key_arn         String   @unique
  recording_arn          String?
  restriction_policy_arn String?
  name                   String
  createdAt              DateTime @default(now())
  User                   User     @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@map("ivs_channels")
}

model Stream {
  idx             Int    @id @default(autoincrement())
  request_id      String
  stream_id       String @unique
  title           String
  start_time      String
  play_cnt        Int    @default(0)
  recommend_cnt   Int    @default(0)
  thumbnail       String @default("")
  broadcaster_idx Int    @unique
  broadcaster     User   @relation("StreamData", fields: [broadcaster_idx], references: [idx], onDelete: Cascade)

  @@map("streams")
}

model PostSettings {
  user_idx         Int       @id
  min_fan_level_id Int?
  created_at       DateTime  @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at       DateTime  @updatedAt
  minFanLevel      FanLevel? @relation(fields: [min_fan_level_id], references: [id])
  user             User      @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@map("post_settings")
}

model Posts {
  id               Int       @id @default(autoincrement())
  content          String
  sent_at          DateTime  @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  read_at          DateTime?
  is_read          Boolean   @default(false)
  sender_deleted   Boolean   @default(false)
  receiver_deleted Boolean   @default(false)
  sender_idx       Int
  receiver_idx     Int
  receiver         User      @relation("ReceivedPosts", fields: [receiver_idx], references: [idx], onDelete: Cascade)
  sender           User      @relation("SentPosts", fields: [sender_idx], references: [idx], onDelete: Cascade)

  @@map("posts")
}

model Fan {
  id               Int      @id @default(autoincrement())
  total_donation   Int      @default(0)
  hidden           Boolean  @default(false)
  current_level_id Int
  created_at       DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at       DateTime @updatedAt
  broadcaster_idx  Int
  fan_idx          Int
  broadcaster      User     @relation("UserFans", fields: [broadcaster_idx], references: [idx], onDelete: Cascade)
  current_level    FanLevel @relation("FanCurrentLevel", fields: [current_level_id], references: [id], onDelete: Cascade)
  fan              User     @relation("UserFollowing", fields: [fan_idx], references: [idx], onDelete: Cascade)

  @@unique([broadcaster_idx, fan_idx])
  @@map("fans")
}

model FanLevel {
  id           Int            @id @default(autoincrement())
  name         String
  min_donation Int
  color        String         @default("#808080")
  created_at   DateTime       @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at   DateTime       @updatedAt
  user_idx     Int
  user         User           @relation("CreatorRankTiers", fields: [user_idx], references: [idx], onDelete: Cascade)
  fans         Fan[]          @relation("FanCurrentLevel")
  postSettings PostSettings[]

  @@unique([user_idx, name])
  @@map("fan_levels")
}

model PostBlockedUsers {
  id          Int      @id @default(autoincrement())
  created_at  DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  blocker_idx Int
  blocked_idx Int
  blocked     User     @relation("PostBlockedUser", fields: [blocked_idx], references: [idx], onDelete: Cascade)
  blocker     User     @relation("PostBlockingUser", fields: [blocker_idx], references: [idx], onDelete: Cascade)

  @@unique([blocker_idx, blocked_idx])
  @@map("post_blocked_users")
}

model Bookmark {
  id             Int      @id @default(autoincrement())
  hidden         Boolean  @default(false)
  created_at     DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  bookmarker_idx Int
  bookmarked_idx Int
  bookmarked     User     @relation("UserBookmarkedBy", fields: [bookmarked_idx], references: [idx], onDelete: Cascade)
  bookmarker     User     @relation("UserBookmarksMade", fields: [bookmarker_idx], references: [idx], onDelete: Cascade)

  @@unique([bookmarker_idx, bookmarked_idx])
  @@map("bookmarks")
}

model Blacklist {
  id              Int      @id @default(autoincrement())
  created_at      DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  broadcaster_idx Int
  blocked_idx     Int
  blocked         User     @relation("BlacklistedUser", fields: [blocked_idx], references: [idx], onDelete: Cascade)
  broadcaster     User     @relation("BlacklistOwner", fields: [broadcaster_idx], references: [idx], onDelete: Cascade)

  @@unique([broadcaster_idx, blocked_idx])
  @@map("blacklists")
}

model Manager {
  id              Int      @id @default(autoincrement())
  created_at      DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  broadcaster_idx Int
  manager_idx     Int
  broadcaster     User     @relation("CreatorManaged", fields: [broadcaster_idx], references: [idx], onDelete: Cascade)
  manager         User     @relation("UserManager", fields: [manager_idx], references: [idx], onDelete: Cascade)

  @@unique([broadcaster_idx, manager_idx])
  @@map("managers")
}

model Article {
  id         Int            @id @default(autoincrement())
  title      String
  content    String
  is_pinned  Boolean        @default(false)
  is_active  Boolean        @default(true)
  view_count Int            @default(0)
  created_at DateTime       @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at DateTime       @updatedAt
  author_idx Int
  images     ArticleImage[]
  author     User           @relation("ArticleAuthor", fields: [author_idx], references: [idx], onDelete: Cascade)

  @@map("articles")
}

model ArticleImage {
  id          Int      @id @default(autoincrement())
  image_url   String
  image_order Int      @default(0)
  created_at  DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  article_id  Int
  article     Article  @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("article_images")
}

model Policy {
  id         Int               @id @default(autoincrement())
  page       String
  title      String
  content    String
  version    String
  is_active  Boolean           @default(true)
  created_at DateTime          @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at DateTime          @updatedAt
  agreements PolicyAgreement[]

  @@map("policies")
}

model PolicyAgreement {
  id             Int      @id @default(autoincrement())
  user_idx       Int
  policy_id      Int
  policy_version String
  agreed_at      DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  ip_address     String?
  policy         Policy   @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  user           User     @relation("UserPolicyAgreements", fields: [user_idx], references: [idx], onDelete: Cascade)

  @@unique([user_idx, policy_id, policy_version])
  @@map("policy_agreements")
}

model Product {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  image_url    String?
  base_coins   Int
  bonus_coins  Int         @default(0)
  total_coins  Int
  base_price   Int         @default(0)
  vat_rate     Int         @default(10)
  price        Int
  product_type String      @default("star")
  is_active    Boolean     @default(true)
  sort_order   Int         @default(0)
  created_at   DateTime    @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at   DateTime    @updatedAt
  topups       CoinTopup[]

  @@map("products")
}

model PaymentTransaction {
  id                    String                   @id @default(cuid())
  user_idx              Int?
  product_id            Int?
  pg_provider           String
  pg_transaction_id     String                   @unique
  payment_method        String?
  bootpay_receipt_id    String?                  @unique
  bootpay_status        Int?
  bootpay_status_locale String?
  amount                Int
  currency              String                   @default("KRW")
  status                PaymentTransactionStatus @default(PENDING)
  requested_at          DateTime                 @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  approved_at           DateTime?
  canceled_at           DateTime?
  paid_at               DateTime?
  pg_response           Json?
  deleted_user_snapshot Json?
  user_deleted_at       DateTime?
  should_delete_at      DateTime?
  topups                CoinTopup[]
  user                  User?                    @relation(fields: [user_idx], references: [idx])

  @@index([pg_provider, bootpay_receipt_id], map: "idx_payment_pg_bootpay_receipt")
  @@map("payment_transactions")
}

model BootpayTransaction {
  id                    String            @id @default(cuid())
  user_idx              Int?
  receipt_id            String            @unique
  order_id              String            @unique
  application_id        String
  price                 Int
  tax_free              Int               @default(0)
  cancelled_price       Int               @default(0)
  cancelled_tax_free    Int               @default(0)
  currency              String            @default("KRW")
  order_name            String
  company_name          String?
  pg                    String
  method                String
  method_symbol         String
  method_origin         String?
  method_origin_symbol  String?
  status                Int
  status_locale         String?
  escrow_status         String?
  escrow_status_locale  String?
  requested_at          DateTime
  purchased_at          DateTime?
  cancelled_at          DateTime?
  gateway_url           String?
  receipt_url           String?
  metadata              Json?
  sandbox               Boolean           @default(false)
  raw_response          Json
  deleted_user_snapshot Json?
  user_deleted_at       DateTime?
  should_delete_at      DateTime?
  created_at            DateTime          @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at            DateTime          @updatedAt
  cardData              BootpayCardData?
  easyData              BootpayEasyData?
  user                  User?             @relation(fields: [user_idx], references: [idx])
  vbankData             BootpayVbankData?
  topups                CoinTopup[]

  @@index([user_idx], map: "idx_bootpay_user")
  @@index([order_id], map: "idx_bootpay_order")
  @@index([status, created_at], map: "idx_bootpay_status_created")
  @@index([purchased_at], map: "idx_bootpay_purchased")
  @@map("bootpay_transactions")
}

model BootpayCardData {
  id                Int                @id @default(autoincrement())
  tid               String
  card_approve_no   String
  card_no           String
  card_company_code String
  card_company      String
  card_type         String
  card_quota        String
  card_interest     String
  receipt_url       String?
  created_at        DateTime           @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  transaction_id    String             @unique
  transaction       BootpayTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@map("bootpay_card_data")
}

model BootpayVbankData {
  id                Int                @id @default(autoincrement())
  tid               String
  bank_name         String
  bank_username     String?
  bank_account      String?
  sender_name       String?
  expired_at        DateTime?
  cash_receipt_tid  String?
  cash_receipt_type String?
  cash_receipt_no   String?
  receipt_url       String?
  created_at        DateTime           @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  transaction_id    String             @unique
  transaction       BootpayTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@map("bootpay_vbank_data")
}

model BootpayEasyData {
  id                   Int                @id @default(autoincrement())
  tid                  String?
  method_origin        String?
  method_origin_symbol String?
  raw_data             Json?
  created_at           DateTime           @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  transaction_id       String             @unique
  transaction          BootpayTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@map("bootpay_easy_data")
}

model CoinTopup {
  id                     String              @id @default(cuid())
  transaction_id         String?
  bootpay_transaction_id String?
  user_idx               Int?
  product_id             Int
  product_name           String
  base_coins             Int
  bonus_coins            Int                 @default(0)
  total_coins            Int
  remaining_coins        Int
  paid_amount            Int
  coin_unit_price        Float
  status                 TopupStatus         @default(PENDING)
  topped_up_at           DateTime            @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  deleted_user_snapshot  Json?
  user_deleted_at        DateTime?
  bootpayTransaction     BootpayTransaction? @relation(fields: [bootpay_transaction_id], references: [id])
  product                Product             @relation(fields: [product_id], references: [id])
  transaction            PaymentTransaction? @relation(fields: [transaction_id], references: [id])
  user                   User?               @relation(fields: [user_idx], references: [idx])
  usages                 CoinUsage[]
  payoutCoins            PayoutCoin[]

  @@index([bootpay_transaction_id], map: "idx_topup_bootpay_transaction")
  @@map("coin_topups")
}

model CoinBalance {
  user_idx       Int      @id
  coin_balance   Int      @default(0)
  total_charged  Int      @default(0)
  total_used     Int      @default(0)
  total_received Int      @default(0)
  created_at     DateTime @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [user_idx], references: [idx], onDelete: Cascade)

  @@map("coin_balances")
}

model Donation {
  id                        String       @id @default(cuid())
  donor_idx                 Int?
  streamer_idx              Int?
  coin_amount               Int
  coin_value                Int
  message                   String?
  donated_at                DateTime     @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  deleted_donor_snapshot    Json?
  deleted_streamer_snapshot Json?
  donor_deleted_at          DateTime?
  streamer_deleted_at       DateTime?
  should_delete_at          DateTime?
  usages                    CoinUsage[]
  donor                     User?        @relation("SentDonations", fields: [donor_idx], references: [idx])
  streamer                  User?        @relation("ReceivedDonations", fields: [streamer_idx], references: [idx])
  payoutCoins               PayoutCoin[]

  @@map("donations")
}

model CoinUsage {
  id          Int         @id @default(autoincrement())
  topup_id    String
  donation_id String?
  used_coins  Int
  used_at     DateTime    @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  donation    Donation?   @relation(fields: [donation_id], references: [id])
  topup       CoinTopup   @relation(fields: [topup_id], references: [id])
  payoutCoin  PayoutCoin?

  @@map("coin_usages")
}

model PayoutCoin {
  id                   String       @id @default(cuid())
  streamer_idx         Int?
  donation_id          String
  usage_id             Int          @unique
  topup_id             String
  coin_amount          Int
  coin_value           Int
  donated_at           DateTime
  settlement_ready_at  DateTime
  status               PayoutStatus @default(PENDING)
  block_reason         String?
  blocked_topup_reason String?
  settlement_id        String?
  last_reviewed_at     DateTime?
  created_at           DateTime     @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at           DateTime     @updatedAt
  donation             Donation     @relation(fields: [donation_id], references: [id])
  settlement           Settlement?  @relation(fields: [settlement_id], references: [id])
  streamer             User?        @relation("PayoutCoins", fields: [streamer_idx], references: [idx])
  topup                CoinTopup    @relation(fields: [topup_id], references: [id])
  usage                CoinUsage    @relation(fields: [usage_id], references: [id])

  @@index([streamer_idx, status, settlement_ready_at], map: "idx_payout_streamer_status_maturity")
  @@index([topup_id], map: "idx_payout_topup")
  @@index([donation_id], map: "idx_payout_donation")
  @@index([settlement_id], map: "idx_payout_settlement")
  @@map("payout_coins")
}

model Settlement {
  id             String           @id @default(cuid())
  streamer_idx   Int?
  period_start   DateTime
  period_end     DateTime
  total_value    Int
  fee_amount     Int
  payout_amount  Int
  status         SettlementStatus @default(PENDING)
  payout_method  String?
  payout_account String?
  admin_memo     String?
  requested_at   DateTime         @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  approved_at    DateTime?
  paid_at        DateTime?
  rejected_at    DateTime?
  reject_reason  String?
  created_at     DateTime         @default(dbgenerated("timezone('Asia/Seoul'::text, now())"))
  updated_at     DateTime         @updatedAt
  payoutCoins    PayoutCoin[]
  streamer       User?            @relation("Settlements", fields: [streamer_idx], references: [idx])

  @@index([streamer_idx, status, period_start], map: "idx_settlement_streamer_status_period")
  @@index([status, created_at], map: "idx_settlement_status_created")
  @@map("settlements")
}

model WidgetToken {
  id             String           @id @default(cuid())
  token          String           @unique
  broadcaster_id Int
  widget_type    WidgetType
  chat_config_id String           @unique
  goal_config_id String           @unique
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  broadcaster    User             @relation(fields: [broadcaster_id], references: [idx])
  chat_config    WidgetChatConfig @relation(fields: [chat_config_id], references: [id])
  goal_config    WidgetGoalConfig @relation(fields: [goal_config_id], references: [id])

  @@index([broadcaster_id])
  @@map("widget_tokens")
}

model WidgetChatConfig {
  id                 String          @id @default(cuid())
  style              ChatWidgetStyle @default(DEFAULT)
  max_messages       Int             @default(5)
  show_profile_image Boolean         @default(true)
  font_size          Int             @default(14)
  show_user_id       Boolean         @default(true)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  widget_token       WidgetToken?

  @@map("widget_chat_configs")
}

model WidgetGoalConfig {
  id             String          @id @default(cuid())
  style          GoalWidgetStyle @default(GOAL_BAR)
  goal_amount    Int             @default(500)
  goal_label     String          @default("리액션 미션 달성까지")
  bg_opacity     Int             @default(55)
  font_size      Int             @default(14)
  animation_type String          @default("slide")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  widget_token   WidgetToken?

  @@map("widget_goal_configs")
}

enum PaymentTransactionStatus {
  PENDING
  WAITING_DEPOSIT
  SUCCESS
  FAILED
  CANCELED
  EXPIRED
}

enum TopupStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  FROZEN
}

enum PayoutStatus {
  PENDING
  MATURED
  BLOCKED
  IN_SETTLEMENT
  SETTLED
}

enum SettlementStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum WidgetType {
  CHAT
  GOAL
}

enum ChatWidgetStyle {
  DEFAULT
  GRADIENT
}

enum GoalWidgetStyle {
  GOAL_BAR
  GOAL_RING
  GOAL_STEP
}
